---
import BaseLayout from '../../layouts/BaseLayout.astro'
import CtaBand from '../../components/CtaBand.astro'

// VPick+ articles
const vpickArticles = [
  { slug: 'what-is-pick-to-voice',         title: 'What is Pick-to-Voice?',                summary: 'A clear definition, how it works, strengths and tradeoffs.' },
  { slug: 'pick-to-voice-vs-multimodal',   title: 'Pick-to-Voice vs Multimodal Picking',   summary: 'Voice only vs voice + screen + scan — when to use which.' },
  { slug: 'what-is-multimodal-picking',    title: 'What Is Multimodal Picking?',           summary: 'How multimodal workflows combine voice, screen, and scanning.' },
  { slug: 'android-for-voice-picking',     title: 'Why Move Pick-to-Voice to Android?',    summary: 'Hardware choice, MDM, cost, flexibility, future-readiness.' },
  { slug: 'scan-driven-mute-mode',         title: 'What is Scan-Driven Mute Mode?',        summary: 'Keep work flowing in noisy zones without losing accuracy.' },
  { slug: 'devices-for-voice-picking',     title: 'What Devices Work with Pick-to-Voice?', summary: 'Handhelds, wearables, Bluetooth scanners, and accessories.' },
  { slug: 'warehouse-device-leasing',      title: 'Warehouse Device Leasing Explained',    summary: "CAPEX vs OPEX, SLAs, refresh cycles, and what's included." },
  { slug: 'what-is-livemap',               title: 'What Is LiveMap™?',                     summary: 'Real-time visibility of active picker locations across the DC floor.' },
]

// FDA audit prep cluster — grouped because they support each other
const auditArticles = [
  { slug: 'fda-inspection-checklist',      title: 'FDA Inspection Checklist for Food Distribution', summary: 'A practical, time-staged checklist for preparing a distribution center, 3PL, or food warehouse for an FDA inspection.' },
  { slug: 'common-fda-483-findings',       title: 'Common FDA Form 483 Findings in Food Distribution', summary: 'The most common observations on Form 483s — what inspectors actually cite, and what the patterns reveal.' },
  { slug: 'what-inspectors-actually-ask',  title: 'FDA Inspector Questions in Food Distribution Audits', summary: 'The specific questions inspectors ask — and the records you need ready in seconds, not hours.' },
]

// Quality & maintenance for distribution (everything else QMS/CMMS-related)
const qmsCmmsArticles = [
  // Category anchors
  { slug: 'what-is-a-cmms',                       title: 'What Is a CMMS?',                                summary: 'A practical guide to computerized maintenance management systems — what they do and how to evaluate them.' },
  { slug: 'what-is-fsma',                         title: 'What Is FSMA?',                                  summary: 'A practical guide to the Food Safety Modernization Act for distribution centers and 3PLs.' },
  { slug: 'what-is-qms-for-distribution',         title: 'What Is a QMS for Distribution?',                summary: 'How distribution QMS differs from manufacturing QMS, and why it matters.' },
  // Positioning
  { slug: 'cmms-for-distribution-centers',        title: "CMMS for Distribution Centers: What's Different", summary: 'What makes maintenance management in DCs different from manufacturing, and what to look for.' },
  { slug: 'why-standalone-cmms-isnt-enough',      title: "Why a Standalone CMMS Isn't Enough",             summary: 'The five gaps a generic CMMS leaves in a regulated distribution operation — and how to close them.' },
  // Tactical / depth
  { slug: 'pm-schedules-that-get-done',           title: 'How to Build PM Schedules That Actually Get Done', summary: 'Pick the right trigger type (calendar, runtime, condition), set the right cadence, and remove friction at the point of work.' },
  { slug: 'mean-kinetic-temperature-explained',   title: 'Mean Kinetic Temperature Explained (USP &lt;1118&gt;)', summary: 'What MKT is, why USP <1118> matters, and how to calculate it.' },
  { slug: 'working-with-outside-contractors',     title: 'Working with Outside Contractors',               summary: 'How tokenized QR access closes the contractor audit gap.' },
]
---
<BaseLayout
  title="Learn — VPick+"
  description="Vendor-neutral answers about voice picking, multimodal warehouse workflows, CMMS, quality management for distribution, FSMA, MKT, FDA inspection prep, and more."
>
  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="separator">›</span>
    <span aria-current="page">Learn</span>
  </nav>

  <section class="hero">
    <div class="container hero-wrap">
      <div class="hero-copy">
        <h1>Learn</h1>
        <p class="lead">Vendor-neutral answers about modern warehouse and distribution operations — picking, maintenance, quality, compliance, and the technology behind them.</p>
      </div>
    </div>
  </section>

  <!-- FDA audit cluster -->
  <section>
    <div class="container">
      <div style="margin-bottom: 2rem;">
        <span class="pill teal">FDA &amp; FSMA</span>
        <h2 style="margin-top: 0.75rem;">Inspection Prep &amp; Audit Readiness</h2>
        <p class="muted">For when an inspection is coming up — or might be.</p>
      </div>
      <div class="grid-2">
        {auditArticles.map((a) => (
          <article class="card hover-lift">
            <h3><a href={`/learn/${a.slug}`} set:html={a.title} /></h3>
            <p class="muted" set:html={a.summary} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Quality & Maintenance broader content -->
  <section class="alt">
    <div class="container">
      <div style="margin-bottom: 2rem;">
        <span class="pill teal">QMS Pro</span>
        <h2 style="margin-top: 0.75rem;">Quality &amp; Maintenance for Distribution</h2>
        <p class="muted">CMMS, quality management, environmental monitoring, FSMA compliance, and operational depth.</p>
      </div>
      <div class="grid-2">
        {qmsCmmsArticles.map((a) => (
          <article class="card hover-lift">
            <h3><a href={`/learn/${a.slug}`} set:html={a.title} /></h3>
            <p class="muted" set:html={a.summary} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- VPick+ articles -->
  <section>
    <div class="container">
      <div style="margin-bottom: 2rem;">
        <span class="pill teal">VPick+</span>
        <h2 style="margin-top: 0.75rem;">Voice &amp; Multimodal Picking</h2>
        <p class="muted">Pick-to-voice, multimodal workflows, Android devices, and warehouse hardware.</p>
      </div>
      <div class="grid-2">
        {vpickArticles.map((a) => (
          <article class="card hover-lift">
            <h3><a href={`/learn/${a.slug}`}>{a.title}</a></h3>
            <p class="muted">{a.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Ready to see it in action?"
    body="Explore the products or try the QMS Pro live demo."
    ctaText="Explore Products"
    ctaHref="/"
  />
</BaseLayout>
