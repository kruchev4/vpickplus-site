---
import BaseLayout from '../../layouts/BaseLayout.astro'
import CtaBand from '../../components/CtaBand.astro'
import ModeIcons from '../../components/ModeIcons.astro'
import { industries, type IndustryContent } from '../../data/industries.ts'

export function getStaticPaths() {
  return industries.map((ind) => ({
    params: { slug: ind.slug },
    props: { industry: ind },
  }))
}

interface Props { industry: IndustryContent }
const { industry } = Astro.props
---
<BaseLayout
  title={`${industry.name} — VPick+`}
  description={industry.heroSub}
>
  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="separator">›</span>
    <a href="/industries">Industries</a>
    <span class="separator">›</span>
    <span aria-current="page">{industry.name}</span>
  </nav>

  <section class="hero">
    <div class="container hero-wrap">
      <div class="hero-copy">
        <h1>{industry.name}</h1>
        <p class="lead">{industry.heroSub}</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="/vpick">See the Product</a>
          <a class="btn btn-ghost" href="/why">Why Multimodal</a>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <ModeIcons />
    </div>
  </section>

  <section class="alt">
    <div class="container">
      <div class="grid-2">
        <article class="card">
          <h2>Why It Works for {industry.shortName}</h2>
          <ul class="list">
            {industry.whyItWorks.map((w) => (
              <li><strong>{w.label}:</strong> {w.body}</li>
            ))}
          </ul>
          <p class="small" style="margin-top:1rem;">
            Learn more:
            <a href="/learn/what-is-multimodal-picking">What Is Multimodal Picking?</a> ·
            <a href="/learn/scan-driven-mute-mode">What is SilentScan™?</a> ·
            <a href="/learn/android-for-voice-picking">Why Android for Pick-to-Voice</a>
          </p>
        </article>

        <aside class="card">
          <h3>{industry.builtFor.heading}</h3>
          <p>{industry.builtFor.body}</p>
          <ul class="checklist">
            {industry.builtFor.checklist.map((c) => <li>{c}</li>)}
          </ul>
          <p style="margin-top:1rem;">
            <a class="btn btn-secondary" href="/leasing">Prefer OPEX? Explore Leasing</a>
          </p>
        </aside>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Common {industry.shortName} Use Cases</h2>
      <div class="grid-3" style="margin-top:1.5rem;">
        {industry.useCases.map((uc) => (
          <article class="card">
            <h3>{uc.title}</h3>
            <p>{uc.body}</p>
          </article>
        ))}
      </div>
      <p style="margin-top:1.5rem;">
        <a class="btn btn-primary" href="mailto:info@vpickplus.us?subject=VPick%2B%20Demo%20Request">Request a Demo</a>
      </p>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
