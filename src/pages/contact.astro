---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout
  title="Contact — VPick+"
  description="Get in touch for demos, pricing, or device leasing information. Supporting operations from pilot to multi-site deployment."
>
  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="separator">›</span>
    <span aria-current="page">Contact</span>
  </nav>

  <section>
    <div class="container">
      <h1 class="section-title">Let's talk about your workflow needs</h1>
      <p class="section-sub">
        Whether you're evaluating voice picking, planning a QMS rollout, or exploring Android-native warehouse workflows — we're here to help.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid-2">
        <div class="card">
          <h3>Quickest path — Email us</h3>
          <div class="stack">
            <a class="btn btn-primary" href="mailto:info@vpickplus.us?subject=VPick%2B%20General%20Inquiry">General Inquiry</a>
            <a class="btn btn-secondary" href="mailto:info@vpickplus.us?subject=VPick%2B%20Demo%20Request">Request a VPick+ Demo</a>
            <a class="btn btn-secondary" href="mailto:info@vpickplus.us?subject=QMS%20Pro%20Inquiry">Discuss QMS Pro Implementation</a>
            <a class="btn btn-secondary" href="mailto:info@vpickplus.us?subject=VPlus%20Device%20Leasing%20Quote%20Request">Request a Leasing Quote</a>
          </div>
          <p class="muted" style="margin-top:14px; font-size:0.9rem;">
            Want to skip the email? <a href="https://qms.vpickplus.us" target="_blank" rel="noopener">Try the QMS Pro live demo</a> first.
          </p>
        </div>

        <div class="card">
          <h3>Direct emails</h3>
          <p><strong>General:</strong> <a href="mailto:info@vpickplus.us">info@vpickplus.us</a></p>
          <p><strong>Support:</strong> <a href="mailto:support@vpickplus.us">support@vpickplus.us</a></p>
          <p><strong>Sales &amp; Partnerships:</strong> <a href="mailto:partners@vpickplus.us">partners@vpickplus.us</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
